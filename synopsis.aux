\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces  Exclusion limits at 95\% \ensuremath  {\text  {CL}}\xspace  for the pair production of top squarks decaying to $\ell \ensuremath  {\PGt  _\mathrm  {h}}\xspace  $ ($\PGm  \ensuremath  {\PGt  _\mathrm  {h}}\xspace  +\Pe  \ensuremath  {\PGt  _\mathrm  {h}}\xspace  $) final states, displayed in the $ {m_{\PSQtDo  }}$-$m_{\PSGczDo  } $ for $x= 0.5$ as described in Eq.\nobreakspace  {}(\ref  {eq:mass}). The color axis represents the observed limit in the cross section, while the black (red) lines represent the observed (expected) mass limits. The signal cross sections are evaluated using NNLO plus next-to-leading logarithmic (NLL) calculations. The solid lines represent the central values. The dashed red lines indicate the region containing 68\% of the distribution of limits expected under the background-only hypothesis. The dashed black lines show the change in the observed limit due to variation of the signal cross sections within their theoretical uncertainties. }}{12}{figure.7}}
\newlabel{fig:2Dlimit}{{7}{12}{Exclusion limits at 95\% \CL for the pair production of top squarks decaying to $\ell \tauh $ ($\PGm \tauh +\Pe \tauh $) final states, displayed in the $ {m_{\PSQtDo }}$-$m_{\PSGczDo } $ for $x= 0.5$ as described in Eq.~(\ref {eq:mass}). The color axis represents the observed limit in the cross section, while the black (red) lines represent the observed (expected) mass limits. The signal cross sections are evaluated using NNLO plus next-to-leading logarithmic (NLL) calculations. The solid lines represent the central values. The dashed red lines indicate the region containing 68\% of the distribution of limits expected under the background-only hypothesis. The dashed black lines show the change in the observed limit due to variation of the signal cross sections within their theoretical uncertainties}{figure.7}{}}
